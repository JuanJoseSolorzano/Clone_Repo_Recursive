{
    "name": "clone-with-submodules",
    "displayName": "Clone With Submodules",
    "description": "A Visual Studio Code extension to clone repositories with submodules.",
    "version": "1.0.1",
    "publisher": "JuanJoseSolorzanoCarrillo",
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/JuanJoseSolorzano/Clone_Repo_Recursive"
    },
    "engines": {
        "vscode": "^1.105.0"
    },
    "categories": [
        "Testing"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "commands": [
            {
                "command": "clone-with-submodules.cloneWithSubmodules",
                "title": "♻️ Git Modules"
            }
        ]
    },
    "main": "./dist/main.js",
    "files": [
        "dist/main.js",
        "images/",
        "README.md",
        "LICENSE.md"
    ],
    "scripts": {
        "compile": "npm run check-types && node esbuild.js",
        "check-types": "tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production"
    },
    "dependencies": {
        "@types/node": "^20.4.2"
    },
    "devDependencies": {
        "@types/vscode": "^1.105.0",
        "@vscode/vsce": "^3.9.2",
        "esbuild": "^0.28.1",
        "typescript": "^6.0.3",
        "webpack": "^5.108.1",
        "webpack-cli": "^7.1.0"
    }
}
